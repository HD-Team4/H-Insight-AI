{
  "name": "purchase-history-s3-sink",
  "config": {
    "connector.class": "io.aiven.kafka.connect.s3.AivenKafkaConnectS3SinkConnector",
    "topics": "hf4.hf4_db.purchase_history",
    "aws.s3.bucket.name": "hf4-datalake",
    "aws.s3.endpoint": "http://minio:9000",
    "aws.s3.region": "us-east-1",
    "aws.access.key.id": "minioadmin",
    "aws.secret.access.key": "minioadmin",
    "format.output.type": "jsonl",
    "file.compression.type": "gzip",
    "file.max.records": "100",
    "file.name.template": "raw/purchase-history/year={{timestamp:unit=yyyy}}/month={{timestamp:unit=MM}}/day={{timestamp:unit=dd}}/{{topic}}-{{partition}}-{{start_offset}}.gz",
    "file.name.timestamp.timezone": "Asia/Seoul",
    "file.name.timestamp.source": "wallclock",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false"
  }
}
