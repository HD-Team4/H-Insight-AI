<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hinsight.product.dao.ProductKeywordDao">

    <select id="findByProductId" parameterType="long" resultType="ProductKeyword">
        SELECT *
        FROM product_keyword
        WHERE product_id = #{productId}
        ORDER BY keyword_id
    </select>

    <select id="findAll" resultType="ProductKeyword">
        SELECT *
        FROM product_keyword
        ORDER BY product_id, keyword_id
    </select>

    <insert id="insert" parameterType="ProductKeyword"
            useGeneratedKeys="true" keyProperty="keywordId">
        INSERT INTO product_keyword (product_id, keyword)
        VALUES (#{productId}, #{keyword})
    </insert>

    <delete id="delete" parameterType="long">
        DELETE FROM product_keyword
        WHERE keyword_id = #{keywordId}
    </delete>

</mapper>
